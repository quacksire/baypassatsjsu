---
import '../styles/global.css';

import "@fontsource-variable/albert-sans"; // Defaults to wght axis
import "@fontsource-variable/albert-sans/wght.css"; // Specify axis
import "@fontsource-variable/albert-sans/wght-italic.css"; // Specify axis and style
import '@fontsource/archivo-black'

import NavbarBaypass from "../components/NavBar"
import {IconBrandInstagram, IconBrandBluesky, IconArrowUp, IconMail} from "@tabler/icons-react";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#0055A2"/>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<link rel="apple-touch-icon" sizes="57x57" href="/apple-icon-57x57.png">
		<link rel="apple-touch-icon" sizes="60x60" href="/apple-icon-60x60.png">
		<link rel="apple-touch-icon" sizes="72x72" href="/apple-icon-72x72.png">
		<link rel="apple-touch-icon" sizes="76x76" href="/apple-icon-76x76.png">
		<link rel="apple-touch-icon" sizes="114x114" href="/apple-icon-114x114.png">
		<link rel="apple-touch-icon" sizes="120x120" href="/apple-icon-120x120.png">
		<link rel="apple-touch-icon" sizes="144x144" href="/apple-icon-144x144.png">
		<link rel="apple-touch-icon" sizes="152x152" href="/apple-icon-152x152.png">
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png">
		<link rel="icon" type="image/png" sizes="192x192"  href="/android-icon-192x192.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
		<meta name="msapplication-TileColor" content="#ffffff">
		<meta name="msapplication-TileImage" content="/ms-icon-144x144.png">


		<title>BayPass at SJSU</title>
		<meta name="description" content="BayPass at SJSU is a student-led initiative to secure affordable, unlimited transit for all students at San Jose State University." />
	</head>
	<body class="bg-white text-black">
	<!-- awww, you like poking around this basic Astro + Tailwind site that we host on Cloudflare? -->
	<!-- we're flattered, but you should at least connect with us on linkedin if you're going to be so nosy. -->
	<!-- https://www.linkedin.com/in/sam-jeffs/ -->
	<!-- https://www.linkedin.com/in/zyjay/ -->
	<!-- we're always looking for more people to help out, so if you want to get involved, reach out! -->
	<!-- just tell us you found this message :3 -->
		<NavbarBaypass client:load/>
		<slot />
	</body>

	<footer class="w-full bg-white text-neutral-800 px-6 py-12 md:px-12 lg:px-24">
		<div class="w-full mx-auto flex flex-col items-center justify-between">
			{/* Center: Socials */}
			<div class="flex gap-6 items-center m-6">
				<a
					href="https://bsky.app/profile/baypassatsjsu.com"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-blue-600 transition"
				>
					<IconBrandBluesky className="w-5 h-5" />
				</a>

				<a
					href="https://instagram.com/baypassatsjsu"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-pink-500 transition"
				>
					<IconBrandInstagram className="w-5 h-5" />
				</a>

				<a
					href="mailto:hi@baypassatsjsu.com"
					target="_blank"
					rel="noopener noreferrer"
					class="hover:text-blue-600 transition"
				>
					<IconMail className="w-5 h-5" />
				</a>
			</div>

			{/* Right: Actions */}
			<div class="flex gap-4 items-center">
				<a
					href="#"
					class="flex items-center gap-1 text-sm text-neutral-800 hover:text-blue-600 transition"
				>
					<IconArrowUp className="w-4 h-4" />
					Back to top
				</a>
			</div>


			<div class="flex gap-4 items-center mt-5">
				<p class="text-sm text-center md:text-left">
					© {new Date().getFullYear()} Sam Jeffs & Zyjay Cruz with design from Joseph Liu<br/>
			</p>
			</div>


		</div>
	</footer>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		scroll-behavior: smooth !important;
	}
</style>
