---
import Layout from "../layouts/Layout.astro";
import { IconMapPin, IconCalendar, IconAlertCircle, IconCheck, IconArrowRight, IconBus, IconParkingCircle, IconBriefcase, IconShare2 } from "@tabler/icons-react";
---

<Layout
    title="The IRA Fee - Learn About BayPass at SJSU"
    description="Learn about the new Instructionally Related Activities fee and what it hold for BayPass. "
>
    <main>
        <!-- Hero -->
        <section class="w-full bg-sjsublue px-6 py-16 md:px-12 lg:px-24">
            <div class="mb-6 w-full text-center mt-15">
                <h1 class="text-5xl uppercase text-white font-extrabold drop-shadow-[1.5px_1.5px_0_var(--color-auggold)]">
                    The IRA Fee
                </h1>
                <h2 class="mt-2 text-2xl md:text-3xl font-semibold text-sjsugold">
                    Everything you need to know about the new Instructionally Related Activities fee
                </h2>
            </div>
        </section>

        <!-- Overview -->
        <section class="w-full bg-white px-6 py-12 md:px-12 lg:px-24">
            <div class="max-w-5xl mx-auto space-y-6 text-lg text-black">
                <p>
                    SJSU is proposing a new <strong class="text-sjsugold">$184.50 per semester</strong> Instructionally Related Activities (IRA) fee to fund multiple student support programs and initiatives. This includes <strong class="text-sjsublue text-xl font-black">BayPass</strong> - unlimited BART, Caltrain, bus, and ferry access across the Bay Area.
                </p>

                <p>
                    Your feedback shapes implementation. The university is using an <strong>alternative consultation process</strong> instead of a simple yes/no vote. This means you can attend open forums to share feedback and help determine how the fee is rolled out and implemented.
                </p>

                <p class="text-base leading-relaxed text-neutral-700">
                    Want the full details? Check out the official SJSU proposal:
                    <a href="https://www.sjsu.edu/studentaffairs/proposed-ira-fee/fee-proposal.php" target="_blank" rel="noopener noreferrer" class="text-sjsugold font-semibold underline decoration-2 underline-offset-2 hover:opacity-80">
                        Fee proposal, breakdown, and FAQs →
                    </a>
                </p>
            </div>
        </section>

        <!-- What the Fee Funds -->
        <section class="w-full bg-neutral-50 px-6 py-16 md:px-12 lg:px-24">
            <h2 class="text-center text-4xl font-black text-sjsublue mb-12">
                What Does the Fee Fund?
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
            <div class="rounded-xl border-2 border-neutral-200 bg-white p-8 shadow-sm">
                <div class="flex items-center gap-3 mb-4">
                    <IconCheck className="w-8 h-8 text-sjsugold shrink-0" />
                    <h3 class="text-xl font-black text-sjsublue">BayPass</h3>
                </div>
                    <p class="text-base leading-relaxed">
                        Unlimited transit access across 23+ Bay Area agencies for commuting to campus and beyond.
                    </p>
                </div>

                <div class="rounded-xl border-2 border-neutral-200 bg-white p-8 shadow-sm">
                    <div class="flex items-center gap-3 mb-4">
                        <IconCheck className="w-8 h-8 text-sjsugold shrink-0" />
                        <h3 class="text-xl font-bold text-sjsublue">Athletics & Intramurals</h3>
                    </div>
                    <p class="text-base leading-relaxed">
                        Support for varsity teams, club sports, and intramural programs.
                    </p>
                </div>

                <div class="rounded-xl border-2 border-neutral-200 bg-white p-8 shadow-sm">
                    <div class="flex items-center gap-3 mb-4">
                        <IconCheck className="w-8 h-8 text-sjsugold shrink-0" />
                        <h3 class="text-xl font-bold text-sjsublue">Spartan Daily</h3>
                    </div>
                    <p class="text-base leading-relaxed">
                        Funding for SJSU's student-run newspaper and media operations.
                    </p>
                </div>

                <div class="rounded-xl border-2 border-neutral-200 bg-white p-8 shadow-sm">
                    <div class="flex items-center gap-3 mb-4">
                        <IconCheck className="w-8 h-8 text-sjsugold shrink-0" />
                        <h3 class="text-xl font-bold text-sjsublue">Student Engagement and Support</h3>
                    </div>
                    <p class="text-base leading-relaxed">
                        Programming, events, and resources that bring students together.
                    </p>
                </div>
            </div>
        </section>

        <!-- Why BayPass Matters -->
        <section class="w-full bg-sjsublue px-6 py-16 md:px-12 lg:px-24">
            <div class="max-w-5xl mx-auto space-y-16">
                <h2 class="text-4xl font-black text-white mb-12">
                    Why BayPass Matters
                </h2>

                <!-- Item 1: Pays for Itself -->
                <div class="flex flex-col-reverse gap-8 md:flex-row md:items-center md:justify-between">
                    <div class="md:w-1/2 text-white text-lg space-y-4">
                        <h3 class="text-3xl font-black text-sjsugold">Pays for Itself</h3>
                        <p>
                            As part of the proposed <strong class="text-sjsugold font-extrabold">$184.50 per semester IRA fee</strong>, BayPass is positioned to be incredibly affordable. For most students, it will pay for itself in just <strong>2-4 weeks of commuting</strong>. If you live farther away, it pays for itself even faster.
                        </p>
                        <p>
                            That means after just a few weeks, you're essentially riding for free for the rest of the semester.
                        </p>
                    </div>
                    <div class="md:w-1/2 flex justify-center">
                        <div class="bg-white/10 backdrop-blur border border-white/20 rounded-xl p-8 text-center">
                            <div class="text-5xl font-black text-sjsugold mb-2">2-4 Weeks</div>
                            <div class="text-white text-lg">to break even</div>
                        </div>
                    </div>
                </div>

                <!-- Item 2: Benefits Everyone -->
                <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
                    <div class="md:w-1/2 flex justify-center">
                        <div class="bg-white/10 backdrop-blur border border-white/20 rounded-xl p-8">
                            <div class="space-y-4 text-white">
                                <div class="flex items-center gap-3">
                                    <IconBus className="w-8 h-8 text-sjsugold shrink-0" />
                                    <span class="text-lg font-semibold">Commuters save on fares</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <IconParkingCircle className="w-8 h-8 text-sjsugold shrink-0" />
                                    <span class="text-lg font-semibold">Parking relief for those who need it</span>
                                </div>
                                <div class="flex items-center gap-3">
                                    <IconBriefcase className="w-8 h-8 text-sjsugold shrink-0" />
                                    <span class="text-lg font-semibold">Opportunities unlocked</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="md:w-1/2 text-white text-lg space-y-4">
                        <h3 class="text-3xl font-black text-sjsugold">Benefits Everyone</h3>
                        <p>
                            Transit commuters save thousands per semester. As more students use BayPass for transit, parking structures experience reduced demand, making it easier for those who still need to drive to find spots quickly. Local students gain access to <strong>job and internship opportunities throughout the Bay Area</strong>.
                        </p>
                        <p>
                            No matter how you get to campus, BayPass helps.
                        </p>
                    </div>
                </div>

                <!-- Item 3: Brings Relief Now -->
                <div class="flex flex-col-reverse gap-8 md:flex-row md:items-center md:justify-between">
                    <div class="md:w-1/2 text-white text-lg space-y-4">
                        <h3 class="text-3xl font-black text-sjsugold">Brings Relief Now</h3>
                        <p>
                            BayPass could launch <strong>as early as next semester</strong>, giving <strong>immediate relief</strong> to students dealing with crowded parking structures and expensive transit costs.
                        </p>
                        <p>
                            Students have waited long enough. The time to act is now.
                        </p>
                    </div>
                    <div class="md:w-1/2 flex justify-center">
                        <div class="bg-sjsugold rounded-xl p-8 text-center text-sjsublue">
                            <div class="text-5xl font-black mb-2">Fall 2026</div>
                            <div class="text-lg font-semibold">Potential launch date</div>
                        </div>
                    </div>
                </div>

                <!-- Item 4: Avoid Delays -->
                <div class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between">
                    <div class="md:w-1/2 flex justify-center">
                        <div class="bg-white/10 backdrop-blur border border-white/20 rounded-xl p-8">
                            <div class="text-center text-white">
                                <div class="text-5xl font-black text-red-400 mb-2">$2,000+</div>
                                <p class="text-lg">Per semester on commuting<br/>without BayPass</p>
                            </div>
                        </div>
                    </div>
                    <div class="md:w-1/2 text-white text-lg space-y-4">
                        <h3 class="text-3xl font-black text-sjsugold">Avoid Delays</h3>
                        <p>
                            Without the IRA fee, BayPass may be delayed to 2027. Students would spend upwards of <strong>$2,000 per semester</strong> on transit and parking costs - far more than the cost of the IRA fee.
                        </p>
                        <p>
                            Delays cost everyone. Let's get this done now.
                        </p>
                    </div>
                </div>

                <!-- Item 5: Parking for Those Who Need It -->
                <div class="flex flex-col-reverse gap-8 md:flex-row md:items-center md:justify-between">
                    <div class="md:w-1/2 text-white text-lg space-y-4">
                        <h3 class="text-3xl font-black text-sjsugold">Parking for Those Who Need It</h3>
                        <p>
                            With widespread BayPass adoption, fewer students will drive to campus. This reduces demand on parking structures, making it significantly easier for those who <strong>still need to drive</strong> to find available spots quickly.
                        </p>
                        <p>
                            Everyone wins: transit users save money, drivers find parking faster, and campus parking works more efficiently.
                        </p>
                    </div>
                    <div class="md:w-1/2 flex justify-center">
                        <div class="bg-white/10 backdrop-blur border border-white/20 rounded-xl p-8 text-center">
                            <IconParkingCircle className="w-16 h-16 text-sjsugold mx-auto mb-4" />
                            <div class="text-white text-lg font-semibold">More spots available faster</div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- How It Works -->
        <section class="w-full bg-neutral-50 px-6 py-16 md:px-12 lg:px-24">
            <div class="max-w-5xl mx-auto">
                <h2 class="text-3xl font-black text-sjsublue mb-8">
                    How the Consultation Process Works
                </h2>

                <p class="text-lg mb-8 text-neutral-700">
                    Unlike a simple referendum vote (yes/no), the alternative consultation process is <strong>feedback-based</strong>. You attend open forums to discuss and share your opinions on the fee, which directly influences how it's implemented.
                </p>

                <p class="text-lg mb-8 text-neutral-700">
                    <strong class="text-sjsublue">This is your chance to shape the proposed IRA fee!</strong> Open-ended responses and honest feedback are what matters most. Tell SJSU what you like and dislike about the proposal.
                </p>

                <p class="text-base text-neutral-600 mb-6">
                    Learn more:
                    <a href="https://www.sjsu.edu/studentaffairs/proposed-ira-fee/faqs.php" target="_blank" rel="noopener noreferrer" class="text-sjsugold font-semibold underline decoration-2 underline-offset-2 hover:opacity-80">
                        Read the FAQ "What does the consultation process entail?" →
                    </a>
                </p>
            </div>
        </section>

        <!-- What You Need To Do -->
        <section class="w-full bg-sjsublue px-6 py-16 md:px-12 lg:px-24">
            <div class="max-w-5xl mx-auto">
                <h2 class="text-3xl font-black text-white mb-12">
                    What You Need To Do
                </h2>

                <div class="space-y-6">
                    <!-- Open Forums -->
                    <div class="rounded-xl bg-white/10 backdrop-blur border border-white/20 p-8">
                        <div class="flex items-start gap-4">
                            <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-sjsugold text-sjsublue font-bold text-xl shrink-0">
                                1
                            </div>
                            <div>
                                <h3 class="text-2xl font-bold text-white mb-3">Attend the Open Forums (Most Important)</h3>
                                <p class="text-white/90 mb-6">
                                    Attend the open forum happening in a hybrid format (in-person or Zoom) to share your feedback on BayPass and the IRA fee.
                                </p>

                                <div class="space-y-4 bg-white/5 rounded-lg p-4">
                                     <div class="border-t border-white/20 pt-4 flex items-start gap-3">
                                          <IconCalendar className="w-5 h-5 text-sjsugold shrink-0 mt-1" />
                                          <div>
                                              <p class="font-semibold text-white">TODAY Tuesday, February 10th, 12–1:30 PM</p>
                                              <p class="text-sm text-white/70">Open Forum - In-Person (Student Union Theatre)</p>
                                              <p class="text-xs text-white/60 mt-2">Downstairs near Starbucks/bowling</p>
                                              <a href="https://calendar.google.com/calendar/event?action=TEMPLATE&tmeid=MDZoM3E2ZXQxOWZpcG4xajRkdTdmNzRlZHAgc2FtLmplZmZzQHNqc3UuZWR1&tmsrc=sam.jeffs%40sjsu.edu" target="_blank" rel="noopener noreferrer" class="text-sjsugold font-semibold text-sm underline event-add-link" data-date="2026-02-10">Add to Calendar →</a>
                                              <a href="https://sjsu.zoom.us/j/87105475875?pwd=EfwxhA1e5zWTDszHJWR2nytdlhayPc.1" target="_blank" rel="noopener noreferrer" class="text-sjsugold font-semibold text-sm underline event-join-link" data-date="2026-02-10">Join the Zoom →</a>
                                          </div>
                                      </div>
                                 </div>

                                <p class="text-white/80 text-sm mt-4">
                                    <strong>In-person attendance is recommended</strong>, but either format works. Pick whichever fits your schedule.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Survey -->
                    <div class="rounded-xl bg-white/10 backdrop-blur border border-white/20 p-8">
                        <div class="flex items-start gap-4">
                            <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-sjsugold text-sjsublue font-bold text-xl shrink-0">
                                2
                            </div>
                            <div>
                                <h3 class="text-2xl font-bold text-white mb-3">Fill Out the IRA Survey (Second Most Important)</h3>
                                <p class="text-white/90 mb-4">
                                    Look for an email from SJSU with a link to the survey, or visit <strong>one.sjsu.edu</strong> to fill it out. Everyone gets an email, so encourage your friends to respond too!
                                </p>
                                <p class="text-white/80 text-sm">
                                    Your feedback directly influences how SJSU finalizes the IRA fee proposal.
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Focus Groups -->
                    <div class="rounded-xl bg-white/10 backdrop-blur border border-white/20 p-8">
                        <div class="flex items-start gap-4">
                            <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-sjsugold text-sjsublue font-bold text-xl shrink-0">
                                3
                            </div>
                            <div>
                                <h3 class="text-2xl font-bold text-white mb-3">Attend Focus Groups (If Applicable)</h3>
                                <p class="text-white/90 mb-4">
                                    If you're part of any of these groups, attend the focus group session for additional feedback opportunities:
                                </p>
                                <div class="text-white/90 space-y-3 mb-4 bg-white/5 rounded-lg p-4">
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 3, 2026</p>
                                        <p class="text-sm">Housing - Theme Community Residents</p>
                                        <p class="text-sm font-medium">10:00 a.m. to 10:50 a.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 4, 2026</p>
                                        <p class="text-sm">Housing - RA Council, RHA, & Student Staff</p>
                                        <p class="text-sm font-medium">2:00 p.m. to 2:50 p.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 5, 2026</p>
                                        <p class="text-sm">Student Employees</p>
                                        <p class="text-sm font-medium">12:00 p.m. to 1:00 p.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 6, 2026</p>
                                        <p class="text-sm">Housing Residents</p>
                                        <p class="text-sm font-medium">2:00 p.m. to 2:50 p.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 9, 2026</p>
                                        <p class="text-sm">Athletes</p>
                                        <p class="text-sm font-medium">6:00 p.m. to 7:00 p.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 10, 2026</p>
                                        <p class="text-sm">Associated Student Affiliates</p>
                                        <p class="text-sm font-medium">1:30 p.m. to 2:30 p.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 16, 2026</p>
                                        <p class="text-sm">Clubs and Orgs, Greek Life</p>
                                        <p class="text-sm font-medium">5:30 p.m. to 6:30 p.m.</p>
                                    </div>
                                    <div class="border-b border-white/20 pb-3">
                                        <p class="font-semibold">Feb 17, 2026</p>
                                        <p class="text-sm">Cultural Centers, EOP, Guardian Scholars</p>
                                        <p class="text-sm font-medium">12:30 p.m. to 1:30 p.m.</p>
                                    </div>
                                    <div>
                                        <p class="font-semibold">Feb 19, 2026</p>
                                        <p class="text-sm">SUI Board of Directors</p>
                                        <p class="text-sm font-medium">1:15 p.m. to 2:45 p.m.</p>
                                    </div>
                                </div>
                                <p class="text-white/80 text-sm mb-3">
                                    All focus groups happen within the first 3 weeks of February.
                                </p>
                                <a href="https://www.sjsu.edu/studentaffairs/proposed-ira-fee/communications.php" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-sjsugold text-sjsublue font-semibold px-4 py-2 rounded-lg hover:bg-clipper transition">
                                    Find focus group dates & times <IconArrowRight className="w-4 h-4" />
                                </a>
                                <p class="text-white/80 text-sm mt-3">
                                    (Scroll down to "Focus Groups" on the page)
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-12 rounded-xl border-2 border-sjsugold bg-yellow-50/10 p-6 text-center">
                    <p class="text-white text-lg font-semibold">
                        We're 95% of the way there to winning BayPass. The finish line is in sight. Come to the open forums, fill out the survey, and help us make affordable transit a reality for all Spartans.
                    </p>
                </div>

                <div class="mx-auto max-w-5xl mt-6 rounded-2xl border border-white/20 bg-white/10 p-6">
                    <h3 class="text-xl font-bold text-white mb-2">How to Give Feedback</h3>
                    <p class="text-lg text-white/90">
                        Tips for sharing honest feedback about the IRA fee and BayPass at the forums.
                        <a
                                href="/ira-feedback-tips"
                                class="text-sjsugold font-semibold underline decoration-2 underline-offset-2 hover:opacity-80"
                        >
                            Read the feedback tips →
                        </a>
                    </p>
                </div>
            </div>
        </section>

        <!-- Share Section -->
        <section class="w-full bg-neutral-50 px-6 py-12 md:px-12 lg:px-24">
            <div class="max-w-2xl mx-auto">
                <div class="rounded-2xl border-2 border-sjsugold bg-white p-8 shade-color-sjsugold drop-6">
                    <div class="flex items-center gap-3 mb-4">
                        <IconShare2 className="h-8 w-8 text-sjsugold" strokeWidth={2.5} />
                        <h3 class="text-2xl font-black text-sjsugold">Spread the Word</h3>
                    </div>
                    <p class="text-clipper mb-4">
                        Help us reach more students about the IRA fee and the open forums. Share with your friends, classmates, and group chats.
                    </p>
                    <ul class="mt-4 list-disc pl-5 text-clipper space-y-1 mb-6">
                        <li>Post on Instagram, TikTok, or Bluesky</li>
                        <li>Tell your friends about the forums</li>
                        <li>Encourage others to fill out the survey</li>
                    </ul>
                    <button
                        id="share"
                        class="button inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide"
                    >
                        Share on Social Media
                    </button>
                </div>
            </div>
        </section>

        <!-- Call to Action -->
        <section class="bg-sjsugold py-12 px-6 md:px-12 lg:px-24 text-center">
            <h3 class="text-3xl font-extrabold text-white mb-4">
                Let's Get BayPassed
            </h3>
            <p class="text-lg text-white max-w-3xl mx-auto mb-6 leading-relaxed">
                Your feedback matters. Come to the open forums, fill out the survey, and tell SJSU what you think about the IRA fee and BayPass. Together, we can make affordable and equitable transit a reality for all Spartans.
            </p>
            <a
                href="/"
                class="mt-2 inline-block rounded-xl font-bold bg-white px-5 py-3 uppercase tracking-wide text-sjsublue shadow-md transition-transform hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-sjsugold/40"
            >
                Learn More About BayPass →
            </a>
        </section>
    </main>
</Layout>

<script is:inline>
    // Handle event links visibility based on date
    function updateEventLinks() {
        const today = new Date();
        today.setHours(0, 0, 0, 0);

        // "Add to Calendar" links: hide on and after the event date
        const addLinks = document.querySelectorAll('.event-add-link');
        addLinks.forEach(link => {
            const dateStr = link.getAttribute('data-date');
            if (dateStr) {
                const eventDate = new Date(dateStr + 'T00:00:00');
                if (today >= eventDate) {
                    link.style.display = 'none';
                }
            }
        });

        // "Join" links: hide before and after the event date
        const joinLinks = document.querySelectorAll('.event-join-link');
        joinLinks.forEach(link => {
            const dateStr = link.getAttribute('data-date');
            if (dateStr) {
                const eventDate = new Date(dateStr + 'T00:00:00');
                const eventDateEnd = new Date(dateStr + 'T23:59:59');
                if (today < eventDate || today > eventDateEnd) {
                    link.style.display = 'none';
                }
            }
        });
    }

    updateEventLinks();

    const shareButton = document.getElementById("share");
    if (shareButton) {
        shareButton.addEventListener("click", () => {
            const shareText =
                "Learn more about the new IRA fee and what it holds for BayPass. https://baypassatsjsu.com/ira";

            // check if Web share API is available
            if (navigator.share) {
                navigator
                    .share({
                        text: shareText,
                    })
                    .catch(console.error);
            }
        });
    }
</script>
