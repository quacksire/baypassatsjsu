---
import Layout from "../layouts/Layout.astro";
import { IconMail, IconCalendarEvent, IconShare2, IconInfoCircle } from "@tabler/icons-react";
---

<Layout
	title='thanks for signing'
	description='here’s what you can do to help out'
>
	<main>
		<!-- Hero -->
		<section class='w-full bg-sjsublue px-6 py-16 md:px-12 lg:px-24'>
			<div class='mb-6 w-full text-center mt-15'>
				<h1
					class='text-5xl uppercase text-white font-extrabold drop-shadow-[1.5px_1.5px_0_var(--color-auggold)]'
				>
					Make Your Voice Heard
				</h1>
				<h2
					class='mt-2 text-2xl md:text-3xl font-semibold text-sjsugold'
				>
					Your feedback shapes how BayPass becomes a reality at SJSU.
				</h2>
			</div>
		</section>

		<!-- Actions -->
		<section class='w-full bg-white px-6 py-16 md:px-12 lg:px-24'>
			<div class='max-w-7xl mx-auto'>
				<div class='mx-auto max-w-5xl mb-10 text-clipper text-lg'>
					<p>
						The IRA fee consultation process is happening now. Student feedback directly shapes how 
						BayPass and other programs are implemented. Attend the forums, fill out the survey, and 
						tell SJSU what you think.
					</p>
				</div>
				<p
					class='mx-auto max-w-3xl text-lg text-sjsugold text-center font-bold leading-relaxed mb-5'
				>
					Here's how to get involved!
				</p>
				<!-- Card grid -->
				<div class='grid grid-cols-1 gap-8 md:grid-cols-2'>

					<!-- Email
					<div
						class='rounded-2xl border-2 border-sjsugold bg-white p-8 shade-color-sjsugold drop-6 flex flex-col'
					>
						<div class='flex items-center gap-3 mb-4'>
							<IconMail
								className='h-8 w-8 text-sjsugold'
								strokeWidth={2.5}
							/>
							<h3 class='text-2xl font-black text-sjsugold'>
								Email
							</h3>
						</div>
						<p class='text-clipper'>
							Use our email tool to contact President Cynthia
							Teniente-Matson and show support for BayPass. Each
							email helps demonstrate that students want
							affordable and equitable transit now.
						</p>
						<ul class='mt-4 list-disc pl-5 text-clipper space-y-1'>
							<li>Pre-filled subject and message</li>
							<li>Add your name and send</li>
							<li>Two minutes, real impact</li>
						</ul>
						<a
							href='/yell'
							class='button mt-12 inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide'
						>
							open email tool
						</a>
					</div>
					-->


					<!-- Attend a board meeting -->
					<div
						class='rounded-2xl border-2 border-sjsugold bg-white p-8 shade-color-sjsugold drop-6 flex flex-col'
					>
						<div class='flex items-center gap-3 mb-4'>
							<IconCalendarEvent
								className='h-8 w-8 text-sjsugold'
								strokeWidth={2.5}
							/>
							<h3 class='text-2xl font-black text-sjsugold'>
								Attend a board meeting
							</h3>
						</div>
						<p class='text-clipper'>
							Public comment moves the needle. Share a one-minute
							statement about how BayPass affects your commute,
							budget, and ability to join campus life. We’ll point
							you to the next dates.
						</p>
						<ul class='mt-4 list-disc pl-5 text-clipper space-y-1'>
							<li>Short prep guide and talking points</li>
							<li>Show up with other students</li>
							<li>Be visible and be heard</li>
						</ul>
					</div>

					<!-- Learn about the IRA Fee -->
					<div
						class='rounded-2xl border-2 border-sjsugold bg-white p-8 shade-color-sjsugold drop-6 flex flex-col'
					>
						<div class='flex items-center gap-3 mb-4'>
							<IconInfoCircle
								className='h-8 w-8 text-sjsugold'
								strokeWidth={2.5}
							/>
							<h3 class='text-2xl font-black text-sjsugold'>
								Learn About the IRA Fee
							</h3>
						</div>
						<p class='text-clipper'>
							The path to BayPass runs through the proposed Instructionally Related Activities (IRA) fee. Understand the proposal, the consultation process, and how you can make your voice heard.
						</p>
						<ul class='mt-4 list-disc pl-5 text-clipper space-y-1'>
							<li>What the IRA fee funds</li>
							<li>How the consultation process works</li>
							<li>Upcoming forums and focus groups</li>
						</ul>
						<a
							href='/ira'
							class='button mt-12 inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide'
						>
							learn more about the ira fee
						</a>
					</div>
				</div>
			</div>

			<div
				class='rounded-2xl border-2 border-sjsugold bg-white p-8 shade-color-sjsugold drop-6 flex flex-col mt-4'
			>
				<div class='flex items-center gap-3 mb-4'>
					<IconMail
						className='h-8 w-8 text-sjsugold'
						strokeWidth={2.5}
					/>
					<h3 class='text-2xl font-black text-sjsugold'>
						Keep Connected to the Cause
					</h3>
				</div>
				<p class='text-clipper text-lg'>
					Stay in the loop with updates, meetings, and action
					opportunities. You can follow or reach out to us through:
				</p>

				<ul class='mt-4 list-disc pl-5 text-clipper space-y-1 '>
					<div class='mt-8 grid grid-cols-1 gap-8 md:grid-cols-2'>
						<a
							href='https://instagram.com/baypassatsjsu'
							target='_blank'
							rel='noopener noreferrer'
							class='button mt-2 inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide'
						>
							Instagram stories and campaign drops
						</a>
						<a
							href='https://www.tiktok.com/@baypassatsjsu'
							target='_blank'
							rel='noopener noreferrer'
							class='button mt-2 inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide'
						>
							TikTok updates
						</a>
						<a
							href='https://bsky.app/profile/baypassatsjsu.com'
							target='_blank'
							rel='noopener noreferrer'
							class='button mt-2 inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide'
						>
							Our Bluesky advocacy news
						</a>
						<a
							href='mailto:hi@baypassatsjsu.com'
							class='button mt-2 inline-block rounded-xl px-5 py-3 font-black uppercase tracking-wide'
						>
							Email us to collaborate or get involved
						</a>
					</div>
				</ul>

				<!-- Closing note -->
				<p class='mt-10 text-center text-sjsuadadarkgrey'>
					Thank you for backing BayPass at SJSU. Your action helps
					classmates get to class, work, and life.
				</p>
			</div>

		</section>
	</main>

	<script is:inline>
		const shareButton = document.getElementById("share");
		if (shareButton) {
			shareButton.addEventListener("click", () => {
				const shareText =
					"I just signed the BayPass petition for affordable transit at SJSU! Join me in making a difference: https://baypassatsjsu.com";
				const shareUrl = "https://baypassatsjsu.com";

				// check if Web share and use it
				navigator
					.share({
						text: shareText,
					})
					.catch(console.error);
			});
		}
	</script>
</Layout>
