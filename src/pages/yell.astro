---
import HeroSectionBaypass from "../components/HeroSectionBaypass";
import EmailYell from "../components/EmailYell.tsx";
import Layout from "../layouts/Layout.astro";


---

<Layout>
  <main>
    <!-- Hero -->
    <section class="w-full bg-sjsublue px-6 py-16 md:px-12 lg:px-24">
      <div class="mb-6 w-full text-center mt-15">
        <h1 class="text-5xl uppercase text-white font-extrabold drop-shadow-[1.5px_1.5px_0_var(--color-auggold)]">Email</h1>
        <h2 class="mt-2 text-2xl md:text-3xl font-semibold text-sjsugold">
          Send a message to the SJSU administration to demand affordable, unlimited transit for all students.
        </h2>
      </div>
    </section>

    <!-- Email Section -->
    <section class="w-full bg-white px-6 py-16 md:px-12 lg:px-24">
      <div class="max-w-7xl mx-auto">
        <div class="mx-auto max-w-4xl mb-10 text-clipper text-lg">
          <EmailYell client:load />
        </div>
      </div>
    </section>
  </main>
</Layout>
