---
const cityCosts = {
    "Castro Valley": 2000.00,
    "Fremont": 956.00,
    "Berkeley": 1336.00,
    "Walnut Creek": 1548.00,
    "Santa Rosa": 4528.00,
    "San Francisco": 1888.00,
    "Mountain View": 872.00,
    "Gilroy": 1232.00,
    "Daly City": 1592.00,
};

import baypassmap from "../assets/baypass-map.png";
---

<section class="bg-white">
    <!-- Heading -->
    <h2 class="sect-title emph-s emph-bb" id="calculate">
        How much could you save?
    </h2>

    <!-- Layout -->
    <div
            class="flex flex-col gap-8 md:flex-row md:items-center md:justify-between max-w-7xl mx-auto"
    >
        <!-- Left: Image -->
        <div class="md:w-1/2 flex justify-center">
            <img
                    src={baypassmap.src}
                    alt="Map showing BayPass coverage"
                    class="w-full max-w-md rounded-lg border-4 border-sjsugold object-cover shade-color-sjsugold drop-8"
            />
        </div>

        <!-- Right: Calculator -->
        <div class="md:w-1/2 text-lg text-black space-y-6">
            <p>
                Students commuting from across the Bay Area often spend hundreds,
                sometimes thousands, just to get to class. That burden falls hardest on
                the
                <strong class="text-sjsublue font-extrabold"
                >38% of SJSU students who commute from outside Santa Clara
                    County</strong
                >.
            </p>

            <p>
                Select a city to see what those students pay today, and how much
                <strong class="text-sjsublue">BayPass</strong> could save them.
            </p>

            <div
                    class="bg-neutral-100 rounded-xl p-6 drop-4 outline-1 outline-sjsuadadarkgrey shade-color-sjsuadadarkgrey"
            >
                <label
                        for="commuteSelector"
                        class="block font-bold text-sjsublue mb-2"
                >
                    Choose a city:
                </label>

                <select
                        id="commuteSelector"
                        class="w-full rounded-md border border-neutral-300 px-4 py-2 bg-white text-black focus:ring-sjsugold focus:outline-none"
                >
                    <option value="" disabled selected>Select a city</option>
                    {Object.keys(cityCosts).map((city) => (
                            <option value={city}>{city}</option>
                    ))}
                </select>

                <div id="commuteResult" class="mt-6 space-y-2 hidden">
                    <p class="text-lg">
                        The average cost for a student commuting from
                        <span id="cityLabel" class="font-bold text-black"></span> via public
                        transit is
                        <span class="font-bold text-red-600" id="costText">$0.00</span> per
                        semester.
                    </p>

                    <p class="text-lg">
                        With <strong class="text-sjsublue">BayPass</strong>, it would cost
                        them up to
                        <span class="font-bold text-green-600">$184.50</span>.
                    </p>

                    <p class="text-xs text-neutral-600 leading-relaxed">
                        SJSU's average tuition is around $4,500 per semester. Calculation is
                        based on 80 round trips per semester and does not include the VTA
                        EcoPass already provided to all SJSU students.
                    </p>
                </div>
            </div>

            <!-- Did You Know -->
            <div
                    class="bg-blue-50 border-l-4 border-sjsublue px-5 py-3 rounded-r-lg mt-6 shadow-sm"
            >
                <p class="text-sjsublue font-bold text-lg mb-1">Did you know?</p>
                <p class="text-black text-base">
                    <strong class="text-sjsublue">BayPass</strong> also covers parking at
                    <strong class="font-extrabold">BART stations</strong>, making commuting even easier and more affordable.
                </p>
            </div>
        </div>
    </div>
</section>

<script is:inline>
    const costs = {
        "Castro Valley": 2000.0,
        "Fremont": 956.0,
        "Berkeley": 1336.0,
        "Walnut Creek": 1548.0,
        "Santa Rosa": 4528.0,
        "San Francisco": 1888.0,
        "Mountain View": 872.0,
        "Gilroy": 1232.0,
        "Daly City": 1592.0,
    };

    document.addEventListener("DOMContentLoaded", () => {
        const selector = document.getElementById("commuteSelector");
        const costText = document.getElementById("costText");
        const cityLabel = document.getElementById("cityLabel");
        const display = document.getElementById("commuteResult");

        selector.addEventListener("change", () => {
            const city = selector.value;
            if (costs[city]) {
                costText.textContent = `$${costs[city].toLocaleString(undefined, {
                    minimumFractionDigits: 2,
                })}`;
                cityLabel.textContent = city;
                display.classList.remove("hidden");
            }
        });
    });
</script>
